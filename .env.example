# Firebase Admin service account (same project as your other apps —
# Firebase Console -> Project Settings -> Service Accounts -> Generate
# new private key). Use a FRESH key, not the one already used elsewhere.
FIREBASE_PROJECT_ID=kapseret-sacco
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# A password only you and your SMS-forwarding app know, so random
# internet traffic can't inject fake transactions. Make up any long
# random string.
SMS_WEBHOOK_SECRET=
